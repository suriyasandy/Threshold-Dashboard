import plotly.graph_objects as go
from sklearn.preprocessing import MinMaxScaler

# Normalize the cluster summary data so all features are between 0 and 1
scaler_minmax = MinMaxScaler()
normalized_summary = pd.DataFrame(
    scaler_minmax.fit_transform(cluster_summary), 
    columns=cluster_summary.columns, 
    index=cluster_summary.index
)

# Initialize Radar Chart
fig = go.Figure()

features = normalized_summary.columns.tolist()

# Add a trace (polygon) for each cluster
for cluster_id in normalized_summary.index:
    values = normalized_summary.loc[cluster_id].tolist()
    # Close the polygon by repeating the first value at the end
    values += values[:1] 
    features_closed = features + features[:1]
    
    fig.add_trace(go.Scatterpolar(
        r=values,
        theta=features_closed,
        fill='toself',
        name=f'Cluster {cluster_id}'
    ))

fig.update_layout(
    polar=dict(radialaxis=dict(visible=True, range=[0, 1])),
    showlegend=True,
    title="Normalized Cluster Profiles (Radar Chart)"
)

fig.show()


