import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
from sklearn.preprocessing import MinMaxScaler

# ---------------------------------------------------------
# 1. DYNAMIC CLUSTER LABELING
# ---------------------------------------------------------
# We dynamically assign labels by sorting the clusters based on average price volatility.
# Lowest Volatility = Highly Liquid. Highest Volatility = Illiquid/Distressed.

# Calculate the mean volatility for the existing integer clusters
cluster_volatility = bond_df.groupby('volatility_cluster')['price_volatility'].mean().sort_values()

# Extract the ordered cluster IDs
ordered_clusters = cluster_volatility.index.tolist()

# Map the ordered IDs to our specific business labels
dynamic_label_map = {
    ordered_clusters[0]: 'Highly Liquid / Stable',
    ordered_clusters[1]: 'Core Corporate / Mid-Market',
    ordered_clusters[2]: 'Illiquid / Distressed'
}

# Apply the dynamic labels to both dataframes
bond_df['cluster_label'] = bond_df['volatility_cluster'].map(dynamic_label_map)

# Merge the new labels back to the raw trade data for the crosstab
df_clustered = pd.merge(
    df, 
    bond_df[['isin', 'cluster_label']], 
    on='isin', 
    how='inner'
)

# ---------------------------------------------------------
# 2. VISUALIZATION 1: BUSINESS CROSSTAB MATRIX
# ---------------------------------------------------------
# Validates the ML grouping against the established credit ratings

# Create the cross-tabulation matrix (normalized as percentages)
crosstab_matrix = pd.crosstab(
    index=df_clustered['cluster_label'], 
    columns=df_clustered['creidtrating'], # Assumes the cleaned categorical rating column
    normalize='index' 
) * 100

plt.figure(figsize=(9, 5))
sns.heatmap(crosstab_matrix, annot=True, cmap="Blues", fmt=".1f")
plt.title("Matrix 1: Business Clusters vs. Credit Ratings (%)", pad=15)
plt.ylabel("Assigned T0 Risk Profile")
plt.xlabel("Original Credit Rating Bucket")
plt.tight_layout()
plt.show()

# ---------------------------------------------------------
# 3. VISUALIZATION 2: CLUSTER FEATURE HEATMAP
# ---------------------------------------------------------
# Proves the statistical boundaries to justify the percentage thresholds

# Group by the new text labels and calculate feature averages
cluster_metrics_labeled = bond_df.groupby('cluster_label')[
    ['trade_count', 'price_volatility', 'avg_spread', 'avg_notional']
].mean()

# Sort the index so it displays logically from Liquid to Illiquid on the chart
label_order = ['Highly Liquid / Stable', 'Core Corporate / Mid-Market', 'Illiquid / Distressed']
cluster_metrics_labeled = cluster_metrics_labeled.reindex(label_order)

# Scale the metrics (0 to 1) purely for the heatmap color gradient
scaler_viz = MinMaxScaler()
metrics_scaled = pd.DataFrame(
    scaler_viz.fit_transform(cluster_metrics_labeled), 
    columns=cluster_metrics_labeled.columns, 
    index=cluster_metrics_labeled.index
)

plt.figure(figsize=(10, 6))
# Plot the scaled colors, but annotate with the real, unscaled numbers
sns.heatmap(
    metrics_scaled, 
    annot=cluster_metrics_labeled.round(2), 
    cmap="YlOrRd", 
    fmt="g",
    cbar_kws={'label': 'Relative Intensity (Scaled)'}
)
plt.title("Matrix 2: Cluster Profile Limits for T0 Thresholds", pad=15)
plt.ylabel("Assigned T0 Risk Profile")
plt.xlabel("Aggregated Bond Metrics")
plt.tight_layout()
plt.show()
