# Calculate the mean of each feature per cluster
cluster_metrics = bond_df.groupby('volatility_cluster')[
    ['trade_count', 'price_volatility', 'avg_spread', 'avg_notional']
].mean()

# Scale the metrics strictly for visual heatmap purposes (0 to 1 scale)
# This allows trade_count (thousands) and avg_spread (decimals) to be colored on the same chart
from sklearn.preprocessing import MinMaxScaler
scaler_viz = MinMaxScaler()
metrics_scaled = pd.DataFrame(
    scaler_viz.fit_transform(cluster_metrics), 
    columns=cluster_metrics.columns, 
    index=cluster_metrics.index
)

# Plot the matrix
plt.figure(figsize=(10, 6))
sns.heatmap(metrics_scaled, annot=cluster_metrics.round(2), cmap="YlOrRd", fmt="g")
plt.title("Cluster Profile Matrix (Raw Values Shown, Colored by Relative Intensity)")
plt.ylabel("ML Cluster")
plt.show()


