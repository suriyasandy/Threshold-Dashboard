print("\nExtracting Threshold Map and False Positive Evidence...")

# --- 1. The Dynamic Threshold Map ---
# This creates a clean table showing exactly what limits the model assigned to each tier
threshold_summary = bond_profiles[['ML_Risk_Tier', 'ML_Limit']].drop_duplicates().sort_values('ML_Limit')
threshold_summary['ML_Limit_Percentage'] = (threshold_summary['ML_Limit'] * 100).astype(str) + '%'

print("\n--- DYNAMIC ML THRESHOLDS USED FOR BACKTESTING ---")
print(threshold_summary[['ML_Risk_Tier', 'ML_Limit_Percentage']].to_string(index=False))

# --- 2. Isolate the False Positives ---
# Filter the dataset to only show trades where the ML model saved the team time
false_positives_df = df_clean_test[
    df_clean_test['Impact_Category'] == 'False Positive Saved (Operational Noise Removed)'
].copy()

# Select only the columns Product Control cares about for their review
columns_to_show = [
    'isin', 
    'product_subtype', 
    'credit_rating', 
    'dealprice', 
    'lseg_mid_price', 
    'ML_Risk_Tier', 
    'ML_Limit', 
    'ML_Lower_Bound', 
    'ML_Upper_Bound',
    'vault_error_description' # Shows them the exact legacy error they used to get
]

# Ensure the columns actually exist in your dataset before filtering
available_columns = [col for col in columns_to_show if col in false_positives_df.columns]
fp_evidence = false_positives_df[available_columns]

# --- 3. Export for Product Control Review ---
fp_file_name = 'Evidence_False_Positives_Suppressed.xlsx'
fp_evidence.to_excel(fp_file_name, index=False)

print(f"\nExtracted {len(fp_evidence)} False Positive trades.")
print(f"Evidence file saved to: {fp_file_name}")
